<section class="customer-reviews">
  <div class="page-width">
    <!-- Heading -->
    <div class="reviews-header">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <!-- Rating Summary -->
    <div style="display: flex; justify-content: center; align-items: center">
        <div class="rating-summary">
            <div style="display: flex; flex-direction: column; justify-content: center; align-items: center">
          <div class="rating-number">
            {{ section.settings.rating }}
          </div>

          {% assign avg_rating = section.settings.rating | round | plus: 0 %}
          <div class="rating-stars">
            {% for i in (1..5) %}
              {% if i <= avg_rating %}
                {% render 'star', class: 'active' %}
              {% else %}
                {% render 'star' %}
              {% endif %}
            {% endfor %}
          </div>
            </div>

          <div class="rating-text">
            Based on <br/><strong>{{ section.settings.review_count }}+ reviews</strong>
          </div>
      </div>
    </div>

    <!-- Reviews Grid -->
    <div class="reviews-grid">
      {% for block in section.blocks %}
        <div class="review-card">
          <div class="review-top">
            <div class="rating-stars">
              {% assign rating = block.settings.star_count | plus: 0 %}

              {% for i in (1..5) %}
                {% if i <= rating %}
                  {% render 'star', class: 'active' %}
                {% else %}
                  {% render 'star' %}
                {% endif %}
              {% endfor %}
            </div>
            <span class="verified">Verified</span>
          </div>

          <p class="review-text">"{{ block.settings.review }}"</p>

          <div class="review-footer">
            <strong>{{ block.settings.name }}</strong>
            <span>{{ block.settings.location }}</span>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="reviews-btn">
      <a href="{{ section.settings.button_link }}">
        {{ section.settings.button_text }}
      </a>
    </div>
  </div>
</section>

<style>
  .customer-reviews{
    padding: 0px 20px;
  }

  /* Header */

  .reviews-header{
    text-align: center;
    margin-bottom: 30px;
  }

  .reviews-header h2{
    font-size: 36px;
    font-weight: 700;
  }

  .reviews-header p{
    color: #6b7280;
  }

  /* Rating summary */

  .rating-summary{
    background: linear-gradient(to right in oklab, rgb(255, 245, 237) 0%, rgb(255, 255, 255) 100%);
    border-radius: 16px;
    padding: 16px 32px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    max-width: 420px;
    margin: 0 auto 50px;
  }

  .rating-number{
    font-size:36px;
    font-weight:700;
    width: fit-content;
  }

  .rating-stars{
    color: #ff7a2f;
    font-size:20px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .rating-stars svg{
    width: 20px;
    stroke : oklch(0.872 0.01 258.338);
  }

  .rating-stars svg.active{
    stroke : #ff7a2f;
    fill: #ff7a2f;
  }

  .rating-text{
    color:#555;
  }

  /* Reviews grid */

  .reviews-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:25px;
  }

  .review-card{
      background:white;
      border-radius:16px;
      padding:25px;
      border:1px solid #e5e7eb;
  }

  .review-card .rating-stars svg{
      width: 16px;
  }

  .review-top{
    display:flex;
    justify-content:space-between;
    margin-bottom:10px;
  }

  .stars{
    color:#ff7a2f;
  }

  .verified{
    background:#e6f4ea;
    color: #2e7d32;
    font-size:12px;
    padding:4px 10px;
    border-radius:8px;
  }

  .review-text{
    color: #4b5563;
    margin:15px 0;
    line-height:1.6;
  }

  .review-footer strong{
    display:block;
  }

  .review-footer span{
    color: #6b7280;
    font-size:14px;
  }

  /* Button */

  .reviews-btn{
    text-align:center;
    margin-top:40px;
  }

  .reviews-btn a{
    padding:12px 28px;
    border-radius:30px;
    border:1px solid #ddd;
    text-decoration:none;
    color: #333;
    font-weight:500;
  }

  .reviews-btn a:hover{
    background: #111;
    color: #fff;
  }

  /* Responsive */

  @media(max-width:900px){

  .reviews-grid{
    grid-template-columns:1fr 1fr;
  }

  }

  @media(max-width:600px){

  .reviews-grid{
    grid-template-columns:1fr;
  }

  }
</style>

{% schema %}
{
  "name": "Customer Reviews",
  "class": "section section--page-width",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real reviews from real people experiencing real benefits."
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Rating",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review Count",
      "default": "500"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Read More Reviews"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],

  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review",
          "label": "Review Text"
        },
        {
          "type": "text",
          "id": "star_count",
          "label": "Stars Count"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location / Date"
        }
      ]
    }
  ],

  "max_blocks": 6,

  "presets": [
    {
      "name": "Customer Reviews",
      "category": "Home Page"
    }
  ]
}
{% endschema %}

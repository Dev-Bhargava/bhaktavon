        "custom_liquid": "<style>\n    /* container */\n  \n    .nutrition-card {\n      margin: auto;\n      width: 100%;\n      background: white;\n      padding: 40px;\n      border-radius: 20px;\n      box-shadow: 0 0 0 1px #e3e6ea inset;\n    }\n  \n    .title {\n      font-size: 28px;\n      font-weight: 700;\n      margin-bottom: 15px;\n    }\n  \n    /* table */\n  \n    table {\n      width: 100%;\n      border-collapse: collapse;\n    }\n  \n    th {\n      text-align: left;\n      font-size: 16px;\n      padding-bottom: 15px;\n      color: #333;\n    }\n  \n    td {\n      padding: 10px 0;\n      font-size: 14px;\n      color: #555;\n    }\n  \n    tr {\n      border-top: 1px solid #e6e6e6;\n    }\n  \n    .highlight {\n      color: #ff7a2f;\n      font-weight: 600;\n    }\n  \n    .note {\n      margin-top: 20px;\n      font-size: 14px;\n      color: #888;\n    }\n  \n    /* MOBILE DESIGN */\n  \n    @media (max-width: 768px) {\n      body {\n        padding: 20px;\n      }\n  \n      .nutrition-card {\n        padding: 28px;\n      }\n  \n      .title {\n        font-size: 28px;\n      }\n  \n      table thead {\n        display: none;\n      }\n  \n      table,\n      tbody,\n      tr,\n      td {\n        display: block;\n        width: 100%;\n      }\n  \n      tr {\n        border-top: 1px solid #e6e6e6;\n        padding: 16px 0;\n      }\n  \n      td {\n        display: flex;\n        justify-content: space-between;\n        padding: 6px 0;\n      }\n  \n      td::before {\n        content: attr(data-label);\n        font-weight: 600;\n        color: #333;\n      }\n    }\n  </style>\n  \n  <div id=\"nutrition-card\" class=\"nutrition-card\">\n    <div class=\"title\">Nutrition Information</div>\n  \n    <table>\n      <thead>\n        <tr style=\"border-top: 0\">\n          <th>Nutrient</th>\n          <th>Per 100ml Serving</th>\n          <!-- <th>% Daily Value</th> -->\n        </tr>\n      </thead>\n  \n      <tbody>\n        <tr>\n          <td data-label=\"Nutrient\">Omega 7</td>\n          <td data-label=\"Per 100ml Serving\">2072.14 mg</td>\n          <!-- <td data-label=\"% Daily Value\">2%</td> -->\n        </tr>\n  \n        <tr>\n          <td data-label=\"Nutrient\">Omega 3</td>\n          <td data-label=\"Per 100ml Serving\">102.04 mg</td>\n          <!-- <td class=\"highlight\" data-label=\"% Daily Value\">200%</td> -->\n        </tr>\n  \n        <tr>\n          <td data-label=\"Nutrient\">Omega 6</td>\n          <td data-label=\"Per 100ml Serving\">423.16 mg</td>\n          <!-- <td class=\"highlight\" data-label=\"% Daily Value\">100%</td> -->\n        </tr>\n  \n        <tr>\n          <td data-label=\"Nutrient\">Omega 9</td>\n          <td data-label=\"Per 100ml Serving\">1683.57 mg</td>\n          <!-- <td data-label=\"% Daily Value\">*</td> -->\n        </tr>\n  \n        <tr>\n          <td data-label=\"Nutrient\">Vitamin C</td>\n          <td data-label=\"Per 100ml Serving\">35.25 mg</td>\n          <!-- <td data-label=\"% Daily Value\">*</td> -->\n        </tr>\n  \n        <tr>\n          <td data-label=\"Nutrient\">Vitamin E</td>\n          <td data-label=\"Per 100ml Serving\">2.57 mg</td>\n          <!-- <td data-label=\"% Daily Value\">*</td> -->\n        </tr>\n  \n        <tr>\n          <td data-label=\"Nutrient\">Beta Carotene</td>\n          <td data-label=\"Per 100ml Serving\">12.68 mg</td>\n          <!-- <td data-label=\"% Daily Value\">*</td> -->\n        </tr>\n  \n        <tr>\n          <td data-label=\"Nutrient\">Energy</td>\n          <td data-label=\"Per 100ml Serving\">34.08 Kcal</td>\n          <!-- <td data-label=\"% Daily Value\">*</td> -->\n        </tr>\n  \n        <tr>\n          <td data-label=\"Nutrient\">Total Carbohydrates</td>\n          <td data-label=\"Per 100ml Serving\">3.88 g</td>\n          <!-- <td data-label=\"% Daily Value\">*</td> -->\n        </tr>\n        \n        <tr>\n          <td data-label=\"Nutrient\">Sugar</td>\n          <td data-label=\"Per 100ml Serving\">0 g</td>\n          <!-- <td data-label=\"% Daily Value\">*</td> -->\n        </tr>\n<tr></tr>\n      </tbody>\n    </table>\n<h5 style=\"margin:0;margin-top: 20px; font-weight: 700 color: #666666\">DIRECTION OF USE</h5>\n\n<p style=\"margin:0; margin-top: 10px; font-weight: 400 color: #e5e5e5\">Take Sea Buckthorn Juice 20 to 25 ml with 100 ml lukewarm water in the early morning on an empty stomach, and take the same dose in the evening 30 minutes before dinner or 50 minutes after dinner.\nUse within 30 days of opening.</p>\n  </div>",

{%- comment -%}
  Snippet: pdp-rating.liquid
  Params:
    rating  — numeric 0–5  (e.g. 4.8)
    count   — string or number (e.g. "500+")
{%- endcomment -%}

<style>
    .divider{
        width: 1px;
        background-color: oklch(0.928 0.006 264.531);
    }

  .rating-number{
    font-size:16px;
    line-height: normal;
    font-weight:500;
    width: fit-content;
    color: #4a5565;
  }

.rating-stars{
    color: #ff7a2f;
    font-size:20px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .rating-stars svg{
    width: 20px;
    stroke : oklch(0.872 0.01 258.338);
  }

  .rating-stars svg.active{
    stroke : #ff7a2f;
    fill: #ff7a2f;
  }

  .rating-text{
    color:#555;
  }
</style>

<div class="rating-summary">
<div style="display: flex; align-items: center; gap: 10px">
    {% assign avg_rating = rating | round | plus: 0 %}
    <div class="rating-stars">
    {% for i in (1..5) %}
        {% if i <= avg_rating %}
        {% render 'star', class: 'active' %}
        {% else %}
        {% render 'star' %}
        {% endif %}
    {% endfor %}
    </div>
    <div class="rating-number">
    {{ rating }}
    </div> 
    <div class="divider"></div>
    <div class="rating-text">
    <strong>{{ count }}</strong>
    </div>
</div>
</div>

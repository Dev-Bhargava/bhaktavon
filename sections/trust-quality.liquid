<section class="trust-quality">
  <div class="page-width">
    
    <div class="trust-header">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <!-- Top Feature Cards -->
    <div class="trust-features">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
        <div class="feature-card">
          <div class="icon">
            {{ block.settings.icon }}
          </div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.text }}</p>
        </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Bottom Quality Section -->
    <div class="quality-wrapper">

      <div class="quality-text">
        <h3>{{ section.settings.quality_heading }}</h3>
        <p>{{ section.settings.quality_text }}</p>

        <ul class="quality-list">
          <li>✔ FSSAI Certified</li>
          <li>✔ ISO Certified Facility</li>
          <li>✔ Third-Party Lab Tested</li>
          <li>✔ Sustainably Sourced</li>
        </ul>
      </div>

      <div class="quality-stats">
        <div class="stat">
          <h4>100%</h4>
          <p>Pure Sea Buckthorn</p>
        </div>

        <div class="stat">
          <h4>0</h4>
          <p>Artificial Additives</p>
        </div>

        <div class="stat">
          <h4>24</h4>
          <p>Month Shelf Life</p>
        </div>

        <div class="stat">
          <h4>5000+</h4>
          <p>Happy Customers</p>
        </div>
      </div>
    </div>

  </div>
</section>


<style>
.section:has(.trust-quality){
    background-image: linear-gradient(oklch(0.985 0.002 247.839) 0%, rgb(255, 255, 255) 100%)
}
.trust-quality{
  padding:80px 20px;
  font-family:system-ui;
}

.page-width{
  max-width:1200px;
  margin:auto;
}

.trust-header{
  text-align:center;
  margin-bottom:40px;
}

.trust-header h2{
  font-size:36px;
  font-weight:700;
}

.trust-header p{
  color:#666;
}

.trust-features{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:20px;
  margin-bottom:40px;
}

.feature-card{
  background:white;
  padding:25px;
  border-radius:14px;
  text-align:center;
  border:1px solid #eee;
}

.feature-card .icon{
  background:#5f8f6e;
  width:60px;
  height:60px;
  border-radius:14px;
  display:flex;
  align-items:center;
  justify-content:center;
  margin:auto auto 15px;
}

.feature-card svg{
  stroke: #ffffff;
}

.feature-card h4{
  font-size:18px;
  margin-bottom:6px;
}

.feature-card p{
  font-size:14px;
  color:#666;
}

.quality-wrapper{
  background:white;
  border-radius:16px;
  padding:40px;
  display:grid;
  grid-template-columns:1.5fr 1fr auto;
  gap:40px;
  align-items:center;
}

.quality-text h3{
  font-size:26px;
  margin-bottom:10px;
}

.quality-text p{
  color:#666;
  margin-bottom:20px;
}

.quality-list{
  list-style:none;
  padding:0;
}

.quality-list li{
  margin-bottom:10px;
  color:#333;
}

.quality-stats{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:15px;
}

.stat{
  background:#f8f8f8;
  padding:20px;
  border-radius:12px;
  text-align:center;
}

.stat h4{
  font-size:28px;
  color:#f57c2a;
  margin-bottom:4px;
}

.stat p{
  font-size:14px;
  color:#666;
}

.quality-btn .btn{
  background:#f57c2a;
  color:white;
  padding:14px 28px;
  border-radius:30px;
  text-decoration:none;
  font-weight:600;
}

@media(max-width:900px){

.trust-features{
  grid-template-columns:repeat(2,1fr);
}

.quality-wrapper{
  grid-template-columns:1fr;
}

.quality-btn{
  margin-top:20px;
}

}
</style>


{% schema %}
{
  "name": "Trust & Quality",
  "class": "section section--page-width",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trust & Quality"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "We're committed to transparency and quality in every bottle we produce."
    },
    {
      "type": "text",
      "id": "quality_heading",
      "label": "Quality Heading",
      "default": "Quality You Can Trust"
    },
    {
      "type": "textarea",
      "id": "quality_text",
      "label": "Quality Description",
      "default": "Our sea buckthorn is sustainably harvested from pristine high-altitude regions and processed using cold-press technology to preserve its nutritional integrity."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View Product"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "SVG Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Lab Tested"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Every batch is tested for purity and safety."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
      {
        "name": "Trust & Quality Section",
        "category": "Home Page"
    }
  ]
}
{% endschema %}
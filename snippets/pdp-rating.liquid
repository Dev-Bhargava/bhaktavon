{%- comment -%}
  Snippet: pdp-rating.liquid
  Params:
    rating  — numeric 0–5  (e.g. 4.8)
    count   — string or number (e.g. "500+")
{%- endcomment -%}

<style>
    .rating-summary{
        background: linear-gradient(to right in oklab, rgb(255, 245, 237) 0%, rgb(255, 255, 255) 100%);
        border-radius: 16px;
        padding: 16px 32px;
        border: 1px solid oklch(0.928 0.006 264.531);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        max-width: 420px;
        margin: 0 auto 50px;
    }

    .rating-summary .divider{;
        width: 1px;
        background-color: oklch(0.928 0.006 264.531);
    }

  .rating-number{
    font-size:36px;
    line-height: normal;
    font-weight:700;
    width: fit-content;
  }

    .rating-stars{
    color: #ff7a2f;
    font-size:20px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .rating-stars svg{
    width: 20px;
    stroke : oklch(0.872 0.01 258.338);
  }

  .rating-stars svg.active{
    stroke : #ff7a2f;
    fill: #ff7a2f;
  }

  .rating-text{
    color:#555;
  }
</style>

<div style="display: flex; justify-content: center; align-items: center">
  <div class="rating-summary">
    <div style="display: flex; justify-content: center; align-items: center; gap: 10px">
      {% assign avg_rating = rating | round | plus: 0 %}
      <div class="rating-stars">
        {% for i in (1..5) %}
          {% if i <= avg_rating %}
            {% render 'star', class: 'active' %}
          {% else %}
            {% render 'star' %}
          {% endif %}
        {% endfor %}
      </div>
      <div class="rating-number">
        {{ rating }}
      </div> 
      <div class="divider"></div>
      <div class="rating-text">
        <strong>{{ count }}</strong>
      </div>
    </div>
  </div>
</div>

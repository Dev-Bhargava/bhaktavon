{%- assign block_settings = block.settings -%}
<div
  id="ProductInformation-{{ section.id }}"
  class="
    product-details
    {% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}
    {% if block_settings.height == 'fill' -%} full-height--desktop{% endif -%}
  "
  style="--details-position: {{ block_settings.details_position }};"
  data-testid="product-information-details"
  {% if settings.transition_to_main_product %}
    data-view-transition-type="product-details"
  {% endif %}
>
  <style>
    /* =========================
       PRODUCT DETAILS WRAPPER
    ========================= */
    .product-details {
      max-width: 480px;
      margin: 0 auto;
    }

    .product-details > * {
      margin-bottom: 18px;
    }

    /* =========================
       BADGES
    ========================= */
    .product-badges {
      display: flex;
      gap: 8px;
    }

    .badge {
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }

    .badge--orange {
      background: #fff5ed;
      color: #ff8c42;
    }

    .badge--green {
      background: #6b9b7d1a;
      color: #6b9b7d;
    }

    /* =========================
       TITLE
    ========================= */
    .product-title {
      font-size: 28px;
      font-weight: 700;
      line-height: 1.2;
    }

    /* =========================
       REVIEWS
    ========================= */
    .product-reviews {
      font-size: 14px;
      color: #555;
    }

    .product-reviews span {
      margin-left: 6px;
    }

    /* =========================
       PRICE
    ========================= */
    .product-price {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .price-current {
      font-size: 28px;
      font-weight: 700;
    }

    .price-old {
      text-decoration: line-through;
      color: #888;
    }

    .price-save {
      background: #e6f4ea;
      color: #2e7d32;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }

    .product-subtext {
      font-size: 14px;
      color: #666;
      margin-top: -8px;
    }

    /* =========================
       BENEFITS
    ========================= */
    .product-benefits h4 {
      font-size: 16px;
      margin-bottom: 8px;
    }

    .product-benefits ul {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px 20px;
      padding: 0;
      list-style: none;
    }

    .product-benefits li {
      position: relative;
      padding-left: 14px;
      font-size: 14px;
      color: #444;
    }

    .product-benefits li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: #ff7a00;
    }

    /* =========================
       PURCHASE OPTIONS
    ========================= */
    .purchase-options h4 {
      font-size: 16px;
      margin-bottom: 10px;
    }

    .option {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border: 2px solid #eee;
      border-radius: 12px;
      padding: 14px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: all 0.2s ease;
      position: relative;
    }

    .option input {
      display: none;
    }

    .option.active,
    .option:hover {
      border-color: #ff7a00;
      background: #fff7f0;
    }

    .option strong {
      display: block;
      font-size: 14px;
    }

    .option p {
      font-size: 13px;
      color: #666;
      margin: 2px 0 0;
    }

    .save-badge {
      background: #ff7a00;
      color: #fff;
      font-size: 11px;
      padding: 4px 8px;
      border-radius: 10px;
    }

    /* =========================
       PRODUCT ACTIONS
    ========================= */
    .product-actions {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .quantity-selector {
      display: flex;
      border: 1px solid #ddd;
      border-radius: 10px;
      overflow: hidden;
    }

    .quantity-selector button {
      background: none;
      border: none;
      padding: 10px 14px;
      cursor: pointer;
      font-size: 16px;
    }

    .quantity-selector input {
      width: 40px;
      text-align: center;
      border: none;
    }

    /* ADD TO CART BUTTON */
    .add-to-cart {
      flex: 1;
      background: #ff7a00;
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 14px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
    }

    .add-to-cart:hover {
      background: #e96d00;
    }

    /* =========================
       SECONDARY ACTIONS
    ========================= */
    .secondary-actions {
      display: flex;
      gap: 10px;
    }

    .secondary-actions button {
      flex: 1;
      padding: 10px;
      border: 1px solid #ddd;
      border-radius: 10px;
      background: #fff;
      cursor: pointer;
    }

    /* =========================
       TRUST BADGES
    ========================= */
    .trust-badges {
      display: flex;
      justify-content: space-between;
      text-align: center;
      margin-top: 20px;
    }

    .trust-badges div {
      font-size: 12px;
      color: #555;
    }

    /* =========================
       IMAGE FIX (IMPORTANT)
    ========================= */
    .media-gallery img {
      object-fit: contain;
      max-height: 600px;
      width: 100%;
    }

    /* =========================
       LAYOUT IMPROVEMENT
    ========================= */
    @media (min-width: 768px) {
      featured-product-information {
        display: grid;
        grid-template-columns: 1fr 1.1fr;
        gap: 40px;
        align-items: center;
      }
    }
  </style>

  <div class="product-badges">
    <span class="badge badge--orange">Best Seller</span>
    <span class="badge badge--green">In Stock</span>
  </div>

  {% capture children %}
    <div class="view-product-title">
      <a
        href="{{ closest.product.selected_or_first_available_variant.url }}"
        class="link"
      >
        {{- closest.product.title }}
      </a>
    </div>

    {% content_for 'blocks' %}
  {% endcapture %}
  
  {% render 'group', children: children, settings: block_settings, shopify_attributes: block.shopify_attributes %}
</div>

{% stylesheet %}
  /* Clear padding on mobile, if not full-width */
  @media screen and (max-width: 749px) {
    .product-information.section--page-width .product-details > .group-block {
      padding-inline: 0;
    }
  }

  .view-product-title {
    display: none;
  }

  /* Container styles */
  .product-details {
    display: flex;
    align-self: start;
    justify-content: center;
  }

  @media screen and (min-width: 750px) {
    .product-details > .group-block {
      height: min-content;
    }

    .full-height--desktop {
      height: 100%;
      max-height: calc(100vh - var(--header-group-height, 0));
      min-height: fit-content;
    }

    .full-height--desktop .group-block {
      align-self: var(--details-position, 'flex-start');
    }
  }
{% endstylesheet %}


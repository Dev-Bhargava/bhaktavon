      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n/* container */\n\n.nutrition-card{\n    margin:auto;\nwidth: 100%;\n    background:white;\n    padding:40px;\n    border-radius:20px;\n    box-shadow:0 0 0 1px #e3e6ea inset;\n}\n\n.title{\n    font-size:28px;\n    font-weight:700;\n    margin-bottom:15px;\n}\n\n/* table */\n\ntable{\n    width:100%;\n    border-collapse:collapse;\n}\n\nth{\n    text-align:left;\n    font-size:16px;\n    padding-bottom:15px;\n    color:#333;\n}\n\ntd{\n    padding: 10px 0;\n    font-size:14px;\n    color:#555;\n}\n\ntr{\n    border-top:1px solid #e6e6e6;\n}\n\n.highlight{\n    color:#ff7a2f;\n    font-weight:600;\n}\n\n.note{\n    margin-top:20px;\n    font-size:14px;\n    color:#888;\n}\n\n\n/* MOBILE DESIGN */\n\n@media(max-width:768px){\n\nbody{\n    padding:20px;\n}\n\n.nutrition-card{\n    padding:28px;\n}\n\n.title{\n    font-size:28px;\n}\n\ntable thead{\n    display:none;\n}\n\ntable, tbody, tr, td{\n    display:block;\n    width:100%;\n}\n\ntr{\n    border-top:1px solid #e6e6e6;\n    padding:16px 0;\n}\n\ntd{\n    display:flex;\n    justify-content:space-between;\n    padding:6px 0;\n}\n\ntd::before{\n    content:attr(data-label);\n    font-weight:600;\n    color:#333;\n}\n\n}\n\n</style>\n\n<div id=\"nutrition-card\" class=\"nutrition-card\">\n\n<div class=\"title\">Nutrition Information</div>\n\n<table>\n\n<thead>\n<tr style=\"border-top: 0;\">\n<th>Nutrient</th>\n<th>Per 30ml Serving</th>\n<th>% Daily Value</th>\n</tr>\n</thead>\n\n<tbody>\n\n<tr>\n<td data-label=\"Nutrient\">Calories</td>\n<td data-label=\"Per 30ml Serving\">45 kcal</td>\n<td data-label=\"% Daily Value\">2%</td>\n</tr>\n\n<tr>\n<td data-label=\"Nutrient\">Vitamin C</td>\n<td data-label=\"Per 30ml Serving\">180 mg</td>\n<td class=\"highlight\" data-label=\"% Daily Value\">200%</td>\n</tr>\n\n<tr>\n<td data-label=\"Nutrient\">Vitamin E</td>\n<td data-label=\"Per 30ml Serving\">15 mg</td>\n<td class=\"highlight\" data-label=\"% Daily Value\">100%</td>\n</tr>\n\n<tr>\n<td data-label=\"Nutrient\">Omega-7 (Palmitoleic Acid)</td>\n<td data-label=\"Per 30ml Serving\">850 mg</td>\n<td data-label=\"% Daily Value\">*</td>\n</tr>\n\n<tr>\n<td data-label=\"Nutrient\">Omega-3 & Omega-6</td>\n<td data-label=\"Per 30ml Serving\">520 mg</td>\n<td data-label=\"% Daily Value\">*</td>\n</tr>\n\n<tr>\n<td data-label=\"Nutrient\">Flavonoids</td>\n<td data-label=\"Per 30ml Serving\">95 mg</td>\n<td data-label=\"% Daily Value\">*</td>\n</tr>\n\n</tbody>\n\n</table>\n\n<div class=\"note\">* Daily Value not established</div>\n\n</div>",

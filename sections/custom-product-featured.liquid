<section class="custom-product">
  <div class="custom-product-wrapper">
    <!-- ================= LEFT: GALLERY ================= -->
    <div class="custom-product-gallery">
      {% assign first_media = section.settings.product.media.first %}

      <div class="main-media">
        <img
          id="main-product-image"
          src="{{ first_media | image_url: width: 900 }}"
          alt="{{ section.settings.product.title }}"
        >
      </div>

      {% if section.settings.product.media.size > 1 %}
        <div class="thumbnail-row">
          {% for media in section.settings.product.media %}
            <img
              class="thumb"
              src="{{ media | image_url: width: 200 }}"
              data-full="{{ media | image_url: width: 900 }}"
              onclick="changeImage(this)"
            >
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- ================= RIGHT: DETAILS ================= -->
    <div class="custom-product-details">
      <!-- BADGES -->
      <div class="product-badges">
        <span class="badge badge--orange">Best Seller</span>

        {% if section.settings.product.available %}
          <span class="badge badge--green">In Stock</span>
        {% endif %}
      </div>

      <!-- TITLE -->
      <h2 class="product-title">
        {{ section.settings.product.title }}
      </h2>

      <!-- REVIEWS (SAFE APP SUPPORT) -->
      <div class="product-reviews">
        {% for block in section.blocks %}
          {% if block.type == '@app' %}
            {% render block %}
          {% endif %}
        {% endfor %}
      </div>

      <!-- PRICE -->
      {% assign v = section.settings.product.selected_or_first_available_variant %}

      <div class="product-price">
        <span class="price-current" id="price-current">
          {{ v.price | money }}
        </span>

        {% if v.compare_at_price > v.price %}
          <span class="price-old" id="price-old">
            {{ v.compare_at_price | money }}
          </span>

          <span class="price-save">
            Save {{ v.compare_at_price | minus: v.price | times: 100 | divided_by: v.compare_at_price }}%
          </span>
        {% endif %}
      </div>

      <p class="product-subtext">500ml bottle (30 servings)</p>

      <!-- ================= VARIANTS ================= -->
      <form method="post" action="/cart/add">
        <input type="hidden" name="id" id="variant-id" value="{{ v.id }}">

        {% unless section.settings.product.has_only_default_variant %}
          {% for option in section.settings.product.options_with_values %}
            <div class="variant-group">
              <label>{{ option.name }}</label>

              <div class="variant-options">
                {% for value in option.values %}
                  <button
                    type="button"
                    class="variant-btn"
                    data-option="{{ option.position }}"
                    data-value="{{ value }}"
                  >
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% endunless %}

        <!-- ================= PURCHASE OPTIONS ================= -->
        <div class="purchase-options">
          <h4>Purchase Options</h4>

          <label class="option active">
            <input type="radio" name="purchase" checked>
            <div>
              <strong>One-time Purchase</strong>
              <p>{{ v.price | money }}</p>
            </div>
          </label>

          <label class="option">
            <input type="radio" name="purchase">
            <div>
              <strong>Subscribe & Save</strong>
              <p>Save 10–15% monthly delivery</p>
            </div>
            <span class="save-badge">Save</span>
          </label>
        </div>

        <!-- ================= ACTIONS ================= -->
        <div class="product-actions">
          <div class="qty">
            <button type="button" onclick="this.nextElementSibling.stepDown()">-</button>
            <input type="number" name="quantity" value="1" min="1">
            <button type="button" onclick="this.previousElementSibling.stepUp()">+</button>
          </div>

          <button type="submit" class="add-to-cart">Add to Cart</button>
        </div>
      </form>

      <!-- TRUST -->
      <div class="trust-badges">
        <div>🚚 Free Shipping</div>
        <div>🛡 Quality Assured</div>
        <div>🔁 Easy Returns</div>
      </div>
    </div>
  </div>
</section>

<style>
      .custom-product-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 40px;
    align-items: center;
  }

  /* GALLERY */
  .main-media img {
    width: 100%;
    border-radius: 16px;
  }

  .thumbnail-row {
    display: flex;
    gap: 10px;
    margin-top: 10px;
  }

  .thumb {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
    border: 1px solid #eee;
  }

  /* DETAILS */
  .custom-product-details {
    max-width: 480px;
  }

  /* BADGES */
  .product-badges {
    display: flex;
    gap: 8px;
  }

  .badge {
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
  }

  .badge--orange { background:#ffe7d6; color:#ff7a00; }
  .badge--green { background:#e6f4ea; color:#2e7d32; }

  /* TITLE */
  .product-title {
    font-size: 28px;
    font-weight: 700;
  }

  /* PRICE */
  .product-price {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .price-current {
    font-size: 28px;
    font-weight: 700;
  }

  .price-old {
    text-decoration: line-through;
    color: #888;
  }

  .price-save {
    background: #e6f4ea;
    color: #2e7d32;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 12px;
  }

  /* VARIANTS */
  .variant-group {
    margin: 15px 0;
  }

  .variant-options {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .variant-btn {
    padding: 8px 12px;
    border: 1px solid #ddd;
    background: #fff;
    border-radius: 8px;
    cursor: pointer;
  }

  .variant-btn.active {
    border-color: #ff7a00;
    background: #fff7f0;
  }

  /* PURCHASE */
  .option {
    border: 2px solid #eee;
    padding: 14px;
    border-radius: 12px;
    margin-bottom: 10px;
    cursor: pointer;
  }

  .option.active {
    border-color: #ff7a00;
    background: #fff7f0;
  }

  /* ACTIONS */
  .product-actions {
    display: flex;
    gap: 10px;
    margin-top: 15px;
  }

  .qty {
    display: flex;
    border: 1px solid #ddd;
    border-radius: 10px;
  }

  .qty button {
    padding: 10px;
    border: none;
    background: #fff;
  }

  .qty input {
    width: 40px;
    text-align: center;
    border: none;
  }

  .add-to-cart {
    flex: 1;
    background: #ff7a00;
    color: #fff;
    border: none;
    border-radius: 10px;
  }

  /* TRUST */
  .trust-badges {
    display: flex;
    justify-content: space-between;
    margin-top: 20px;
    font-size: 12px;
  }
</style>

<script>
    function changeImage(el) {
  document.getElementById('main-product-image').src = el.dataset.full;
}

const product = {{ section.settings.product | json }};
let selected = {};

document.querySelectorAll('.variant-btn').forEach(btn => {
  btn.addEventListener('click', () => {

    const index = btn.dataset.option - 1;
    selected[index] = btn.dataset.value;

    document.querySelectorAll(`[data-option="${btn.dataset.option}"]`)
      .forEach(b => b.classList.remove('active'));

    btn.classList.add('active');

    const variant = product.variants.find(v =>
      v.options.every((opt, i) => opt === selected[i])
    );

    if (variant) {
      document.getElementById('variant-id').value = variant.id;

      document.getElementById('price-current').innerHTML =
        Shopify.formatMoney(variant.price);

      if (variant.compare_at_price > variant.price) {
        document.getElementById('price-old').innerHTML =
          Shopify.formatMoney(variant.compare_at_price);
      }
    }
  });
});
</script>

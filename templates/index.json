            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 35,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "accordion_row_GzxidT": {
              "type": "_accordion-row",
              "settings": {
                "heading": "What does sea buckthorn juice taste like?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_NUYHMk": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Sea buckthorn has a unique tart and tangy flavor profile, similar to a combination of orange and mango with a slight sourness. While the taste is intense when consumed straight, many customers find it pleasant when diluted with water or mixed into smoothies and juices.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_NUYHMk"
              ]
            },
            "accordion_row_T4cEBk": {
              "type": "_accordion-row",
              "settings": {
                "heading": "How should I store the juice?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_YPEgKb": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Store unopened bottles in a cool, dry place away from direct sunlight. Once opened, refrigerate immediately and consume within 30 days. The juice should be stored at 2-4°C for optimal freshness. Shake well before each use.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",

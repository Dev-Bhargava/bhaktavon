                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_YPEgKb"
              ]
            },
            "accordion_row_7JBatb": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Who should consume sea buckthorn juice?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_Mm46T4": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Sea buckthorn juice is suitable for most adults looking to support their immunity, digestive health, and skin wellness. It's especially beneficial for urban professionals dealing with stress and those seeking natural nutritional support. However, pregnant or nursing women and individuals with medical conditions should consult their healthcare provider before use.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,

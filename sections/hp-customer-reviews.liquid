        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-5 h-5 fill-[#FF8C42] text-[#FF8C42]">
            <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-5 h-5 fill-[#FF8C42] text-[#FF8C42]">
            <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-5 h-5 fill-[#FF8C42] text-[#FF8C42]">
            <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-5 h-5 fill-[#FF8C42] text-[#FF8C42]">
            <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
        </svg>
      </div>

      <div class="rating-text">
        Based on <strong>{{ section.settings.review_count }}+ reviews</strong>
      </div>
    </div>

    <!-- Reviews Grid -->
    <div class="reviews-grid">

      {% for block in section.blocks %}
      <div class="review-card">

        <div class="review-top">
          <div class="stars">★★★★★</div>
          <span class="verified">Verified</span>
        </div>

        <p class="review-text">
          "{{ block.settings.review }}"
        </p>

        <div class="review-footer">
          <strong>{{ block.settings.name }}</strong>
          <span>{{ block.settings.location }}</span>
        </div>

      </div>
      {% endfor %}

    </div>

    <div class="reviews-btn">
      <a href="{{ section.settings.button_link }}">
        {{ section.settings.button_text }}
      </a>
    </div>

  </div>
</section>

<style>

.customer-reviews{
  padding: 0px 20px;
}

/* Header */

.reviews-header{
  text-align: center;
  margin-bottom: 30px;
}

.reviews-header h2{
  font-size: 36px;
  font-weight: 700;
}

.reviews-header p{
  color: #6b7280;
}

/* Rating summary */

.rating-summary{
  background: #f2ebe5;
  border-radius: 16px;
  padding: 25px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
  max-width: 420px;
  margin: 0 auto 50px;
}

.rating-number{
  font-size:36px;
  font-weight:700;
}

.rating-stars{
  color: #ff7a2f;
  font-size:20px;
  display: flex;
  align-items: center;
  gap: 4px;
}

.rating-stars svg{
  width: 20px;
  stroke : #ff7a2f;
}

.rating-text{
  color:#555;
}

/* Reviews grid */

.reviews-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:25px;
}

.review-card{
  background:white;
  border-radius:16px;
  padding:25px;
  border:1px solid #e5e7eb;
}

.review-top{
  display:flex;
  justify-content:space-between;
  margin-bottom:10px;
}

.stars{
  color:#ff7a2f;
}

.verified{
  background:#e6f4ea;
  color: #2e7d32;
  font-size:12px;
  padding:4px 10px;
  border-radius:8px;
}

.review-text{
  color: #4b5563;
  margin:15px 0;
  line-height:1.6;
}

.review-footer strong{
  display:block;
}

.review-footer span{
  color: #6b7280;
  font-size:14px;
}

/* Button */

.reviews-btn{
  text-align:center;
  margin-top:40px;
}

.reviews-btn a{
  padding:12px 28px;
  border-radius:30px;
  border:1px solid #ddd;
  text-decoration:none;
  color: #333;
  font-weight:500;
}

.reviews-btn a:hover{
  background: #111;
  color: #fff;
}

/* Responsive */

@media(max-width:900px){

.reviews-grid{
  grid-template-columns:1fr 1fr;
}

}

@media(max-width:600px){

.reviews-grid{
  grid-template-columns:1fr;
}

}

</style>


{% schema %}
{
  "name": "Customer Reviews",
  "class": "section section--page-width",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real reviews from real people experiencing real benefits."
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Rating",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review Count",
      "default": "500"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Read More Reviews"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],

  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review",
          "label": "Review Text"
        },
        {
          "type": "text",
          "id": "star_count",
          "label": "Stars Count"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location / Date"
        }
      ]
    }
  ],

  "max_blocks": 6,

  "presets": [
    {
      "name": "Customer Reviews",
      "category": "Home Page"
    }
  ]
}
{% endschema %}